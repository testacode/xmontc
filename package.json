{
  "name": "xmontc",
  "version": "0.1.0",
  "description": "Carlos Monti's interactive terminal portfolio. Run `npx xmontc`.",
  "type": "module",
  "bin": {
    "xmontc": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/index.js",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "npm run lint && npm run test && npm run build",
    "prepublishOnly": "npm run check"
  },
  "keywords": [
    "cli",
    "portfolio",
    "resume",
    "ink",
    "terminal"
  ],
  "author": "Carlos Monti (https://carlosmonti.com)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/testacode/xmontc.git"
  },
  "dependencies": {
    "ink": "^7.1.0",
    "open": "^11.0.0",
    "react": "^19.2.7"
  },
  "devDependencies": {
    "@types/node": "^25.0.10",
    "@types/react": "^19.2.17",
    "ink-testing-library": "^4.0.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  }
}
